{
  "name": "sentry-testkit-monorepo",
  "private": true,
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "yarn workspace sentry-testkit build",
    "test": "yarn workspace sentry-testkit test",
    "test:expo": "yarn workspace expo-react-native-test-app test",
    "lint": "yarn workspace sentry-testkit lint"
  }
}
